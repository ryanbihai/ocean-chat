# OceanBus SDK 环境变量配置
# 复制此文件为 .env 并填写真实值

# Agent 身份凭证
OCEANBUS_AGENT_ID=your_agent_id
OCEANBUS_API_KEY=sk_live_xxxxxxxxxxxx

# OceanBus API 端点（可选，默认使用公共测试服务器）
OCEANBUS_BASE_URL=https://ai-t.ihaola.com.cn/api/l0

# Yellow Pages 服务 OpenID（必填 — 联系管理员获取）
OCEANBUS_YP_OPENIDS=xxxxxxxxxxxx

# Reputation 服务 OpenID（必填 — 联系管理员获取）
OCEANBUS_REP_OPENID=xxxxxxxxxxxx

# 可选配置
# OCEANBUS_TIMEOUT=10000
# OCEANBUS_POLL_INTERVAL=2000
