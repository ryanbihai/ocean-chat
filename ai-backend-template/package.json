{
  "name": "ai-backend-template",
  "version": "1.0.0",
  "description": "基于 AI 开发规范的 Node.js 后端服务模板",
  "main": "src/server.js",
  "scripts": {
    "start": "NODE_ENV=production node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "start:local": "NODE_ENV=local node src/server.js",
    "start:dev": "NODE_ENV=development node src/server.js",
    "task": "NODE_ENV=production node src/task.js",
    "task:local": "NODE_ENV=local node src/task.js",
    "task:dev": "NODE_ENV=development node src/task.js",
    "dev": "NODE_ENV=development node src/server.js",
    "local": "cross-env NODE_ENV=local node src/server.js",
    "pm2:local": "pm2 start pm2-start-local.json",
    "pm2:dev": "pm2 start pm2-start-dev.json",
    "pm2:prod": "pm2 start pm2-start.json --env production",
    "test:unit": "ava"
  },
  "dependencies": {
    "bullmq": "^5.71.0",
    "colors": "^1.4.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "superagent": "^8.1.2",
    "tracer": "^1.3.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "ava": "^5.3.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.51.0",
    "pm2": "^5.3.0"
  }
}