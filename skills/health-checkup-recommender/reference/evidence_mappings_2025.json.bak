  "explanation_mappings": {

    "item007_chest_ct": {
      "item_id": "item007",
      "item_name": "胸部CT",
      "original_name": "低剂量螺旋CT (LDCT)",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，低剂量螺旋CT（LDCT）是肺癌筛查的首选手段。本项目库以胸部CT替代。对于有肺癌风险因素（如长期吸烟史、职业暴露史、慢性肺部疾病史、肺癌家族史等）的人群，建议定期进行LDCT筛查。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "低剂量螺旋CT辐射剂量低（仅为常规CT的1/4-1/6），能发现微小病灶，显著提高早期肺癌检出率。研究显示LDCT筛查可将肺癌死亡率降低约20%。",
      "applicable_risks": ["肺癌", "肺癌筛查", "咳嗽/呼吸困难", "男性50岁+"],
      "age_recommendation": "30岁以上有肺癌风险因素者，或50岁以上吸烟者",
      "personal_explanations": {
        "default": "胸部CT是筛查肺癌的金标准初筛手段。不同于普通胸片，CT可以发现直径仅几毫米的微小病灶，将肺癌早期发现率提高3倍以上。",
        "with_smoking": "根据您的吸烟史（每年超过20包），您属于肺癌高危人群。《中国肺癌筛查与预防指南》明确建议：吸烟≥20包/年的人群应每年进行低剂量CT筛查。胸部CT辐射剂量仅约1-2mSv，相当于接受约10次X光片的辐射量，但筛查效果远优于胸片。",
        "with_symptom_cough": "您有咳嗽症状，这需要认真对待。胸部CT可以：① 发现肺部肿块或结节，鉴别良性恶性；② 评估气管、支气管有无狭窄或炎症；③ 排除肺炎、肺结核等感染性疾病。这是排查肺部问题最直接、最有效的检查手段。",
        "age_above_50_male": "根据国家癌症中心2022年数据，50岁以上男性肺癌发病率位居所有癌症首位。胸部CT作为无创筛查手段，可以发现早期肺癌，此时治疗效果最佳，5年生存率可达90%以上。建议您将胸部CT纳入每年体检的常规项目。",
        "with_family_history": "您有肺癌家族史，这意味着您的遗传风险较高。研究表明，有一级亲属（父母、兄弟姐妹）患肺癌者，发病风险增加约1.5-2倍。胸部CT可以建立肺部基线档案，便于医生长期追踪肺部变化，早发现、早干预。"
      }
    },

    "item067_pulmonary_function": {
      "item_id": "item067",
      "item_name": "肺功能",
      "original_name": "肺功能检查",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，40岁以上人群建议增加肺功能检查，评估呼吸系统健康。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "评估呼吸系统通气功能，筛查慢性阻塞性肺疾病(COPD)和支气管哮喘等。",
      "applicable_risks": ["咳嗽/呼吸困难"],
      "age_recommendation": "40岁以上",
      "personal_explanations": {
        "default": "肺功能检查通过测量您的呼气流速和肺活量，可以评估呼吸道通畅程度和肺的换气功能。这项检查无创、无痛，大约需要10分钟。",
        "with_symptom_breath": "您有呼吸困难或胸闷症状，肺功能检查可以帮助医生了解：① 您的呼吸道是否存在阻塞（如哮喘、慢阻肺）；② 肺的换气功能是否正常；③ 症状是否与肺部疾病相关。这是呼吸系统疾病诊断的重要依据。",
        "age_above_40": "40岁以后，我们的肺功能会逐渐下降，每年下降约20-30ml。研究显示，40岁以上人群中慢阻肺患病率高达13.7%。肺功能检查可以早期发现肺功能减退，此时通过干预（如戒烟、呼吸训练）可以显著延缓病情进展。",
        "with_smoking": "长期吸烟会导致气道慢性炎症和肺组织破坏，最终发展为慢阻肺。肺功能检查可以客观评估您的肺部受损程度，还能帮助您直观看到吸烟对肺部的实际影响，是戒烟最有说服力的'铁证'。"
      }
    },

    "item098_bone_density": {
      "item_id": "item098",
      "item_name": "骨密度检测",
      "original_name": "骨密度检测",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，40岁以上人群建议增加骨密度检测，尤其绝经后女性。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "早期发现骨质疏松风险，预防骨折。骨密度下降是可逆的，早期干预效果好。",
      "applicable_risks": ["女性40岁+"],
      "age_recommendation": "40岁以上，尤其女性绝经后",
      "personal_explanations": {
        "default": "骨密度检测通过测量骨骼中的矿物质含量（主要是钙），评估骨骼强度。检测方法简单、无创，只需10-15分钟，不会引起不适。",
        "age_above_50_female": "根据《中国骨质疏松症诊疗指南》，50岁以上女性骨质疏松患病率高达32.1%。女性绝经后，雌激素水平急剧下降，导致骨骼中的钙流失加速。骨密度检测可以：① 确诊您是否患有骨质疏松；② 评估骨折风险；③ 指导补钙和运动方案。早期发现骨质疏松，通过补钙、维生素D和负重运动，可以有效逆转。",
        "with_menopause": "女性绝经后，骨骼的'建筑材料'流失速度远快于'建设速度'。骨密度检测可以告诉您：① 您的骨骼现在有多'脆'；② 与同龄人相比处于什么水平；③ 需要采取什么措施来加固骨骼。及时干预可以将骨折风险降低30-50%。",
        "age_above_65": "65岁以上老年人跌倒风险极高，而骨质疏松使跌倒后骨折（尤其是髋部骨折）的后果极为严重。髋部骨折后一年死亡率高达20-30%。骨密度检测可以评估您的骨折风险，医生会根据结果建议您是否需要药物治疗来强化骨骼。"
      }
    },

    "item036_carotid_ultrasound": {
      "item_id": "item036",
      "item_name": "颈动脉彩超",
      "original_name": "颈动脉超声",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，心血管高风险人群建议进行血管超声检查，评估颈动脉斑块情况。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "评估血管斑块和狭窄情况，预警中风风险。颈动脉是全身动脉硬化的窗口。",
      "applicable_risks": ["心脑血管", "头痛/头晕", "高血压", "心脑血管风险"],
      "age_recommendation": "45岁以上有心脑血管风险因素者",
      "personal_explanations": {
        "default": "颈动脉超声通过高频探头观察颈动脉内壁，可以发现早期的动脉粥样硬化斑块。颈动脉是连接心脏和大脑的重要血管，它的健康状况直接反映全身动脉硬化程度。",
        "with_hypertension": "高血压是动脉硬化的'加速器'。长期高血压会损伤血管内皮，促进斑块形成。颈动脉超声可以：① 直观看到您的血管壁是否已经变厚；② 是否已有斑块形成；③ 斑块的性质（软斑块更危险）。这些信息可以帮助医生调整降压方案，降低中风风险。",
        "with_family_history": "您有心血管病家族史，意味着您携带了'易感基因'，动脉硬化可能比同龄人更早、更严重。颈动脉超声可以：① 评估您目前的血管健康状况；② 早期发现斑块并监测其变化；③ 为医生提供是否需要药物干预的依据。",
        "with_symptom_headache": "您有头痛或头晕症状，这可能与脑血管供血有关。颈动脉超声可以：① 评估向大脑供血的主要通道是否通畅；② 排查是否存在影响大脑供血的斑块；③ 判断您的症状是否与颈动脉狭窄相关。这项检查无创、无辐射，是排查脑血管问题的首选。"
      }
    },

    "item112_tcd": {
      "item_id": "item112",
      "item_name": "经颅多普勒(TCD)",
      "original_name": "经颅多普勒",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，有头痛头晕症状或脑血管风险人群建议进行TCD检查。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "评估颅内血管血流动力学，筛查脑血管狭窄、痉挛等异常。",
      "applicable_risks": ["头痛/头晕", "心脑血管"],
      "age_recommendation": "有相关症状者",
      "personal_explanations": {
        "default": "经颅多普勒（TCD）利用超声波穿透颅骨，检测颅内主要动脉的血流速度、方向和性质。这项检查无创、无辐射，可以评估脑血管功能状态。",
        "with_symptom_headache": "您有头痛症状，TCD可以帮助医生了解：① 您的大脑供血是否充足；② 主要脑血管是否存在狭窄或痉挛；③ 头痛是否与脑血管问题相关。这是排查血管性头痛的重要依据。",
        "with_hypertension": "高血压会增加脑血管病变风险。TCD可以：① 评估高血压对脑血管的长期影响；② 排查是否存在脑血管狭窄；③ 了解脑血管的自动调节功能是否正常。",
        "with_family_history": "您有心脑血管病家族史，脑血管可能已经存在潜在病变。TCD可以：① 早期发现脑血管功能异常；② 评估中风风险；③ 为预防性治疗提供依据。"
      }
    },

    "item069_fecal_occult_blood": {
      "item_id": "item069",
      "item_name": "粪便隐血试验定量",
      "original_name": "粪便隐血",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，结直肠癌高风险人群（50岁以上、肥胖或有家族史等）应进行粪便隐血筛查。本项目库以粪便隐血定量替代肠镜。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "早期发现消化道出血，辅助结直肠癌筛查。定量检测比定性更准确。",
      "applicable_risks": ["结直肠癌", "便秘/便血", "腹泻", "腹痛/腹胀"],
      "age_recommendation": "50岁以上，或有消化道症状者",
      "personal_explanations": {
        "default": "粪便隐血定量检测可以检出肉眼看不见的微量血液，这是结直肠癌的重要早期信号。研究显示，每年进行粪便隐血筛查可以降低结直肠癌死亡率约15-33%。定量检测比定性更准确，可以监测出血量的变化。",
        "age_above_50": "根据国家癌症中心数据，50岁以上人群结直肠癌发病率显著上升。《中国结直肠癌筛查与早诊早治指南》推荐：50岁以上人群应每年进行粪便隐血筛查。早期结直肠癌甚至早期腺瘤常常没有明显症状，只能通过隐血试验发现。",
        "with_symptom_constipation": "您有便秘症状，长期便秘可能导致肠道毒素积累，增加结直肠癌风险。粪便隐血检测可以：① 排查是否有肠道出血；② 评估便秘是否已造成肠道损伤；③ 早期发现结直肠癌或腺瘤性息肉。",
        "with_family_history": "您有结直肠癌或肠息肉家族史，您的发病风险是普通人的2-3倍。《指南》建议：有家族史者应提前至40岁开始筛查，并增加筛查频率。粪便隐血检测是经济、便捷的初筛手段，如果结果阳性再考虑肠镜检查。"
      }
    },

    "item016_gastric_function": {
      "item_id": "item016",
      "item_name": "胃功能3项",
      "original_name": "胃功能3项",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，胃癌高风险人群建议进行胃功能检查。本项目库以胃功能3项（PGI+PGII+PGR）替代胃镜。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "评估胃粘膜功能和胃癌风险，比胃镜创伤小，可作为初筛手段。",
      "applicable_risks": ["胃癌", "胃部不适", "腹痛/腹胀"],
      "age_recommendation": "40岁以上有消化道症状或胃癌高风险者",
      "personal_explanations": {
        "default": "胃功能3项包括胃蛋白酶原I（PGI）、胃蛋白酶原II（PGII）及其比值（PGR）。这些指标可以间接反映胃粘膜的健康状态和胃癌风险。抽血即可检测，方便、无创。",
        "with_symptom_stomach": "您有胃部不适症状（如腹胀、反酸、胃痛），胃功能检查可以：① 评估您的胃粘膜是否已经受损；② 排查是否存在萎缩性胃炎（胃癌前病变）；③ 判断您是否需要进一步做胃镜检查。这是胃部疾病筛查的'前沿哨兵'。",
        "age_above_40": "40岁以后，胃癌发病率逐年上升。《中国胃癌筛查与早诊早治指南》推荐：40岁以上人群或有消化道症状者应定期进行胃癌筛查。胃功能3项是理想的无创初筛手段，如果指标异常再考虑胃镜。",
        "with_family_history": "您有胃癌家族史，属于胃癌高危人群。胃功能检查可以：① 建立胃粘膜健康的基线档案；② 监测胃粘膜变化趋势；③ 及早发现胃癌前病变，为早期干预争取时间。"
      }
    },

    "item154_gastric_full": {
      "item_id": "item154",
      "item_name": "胃功能全项",
      "original_name": "胃功能全项（含G-17）",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，胃癌高风险人群建议进行更全面的胃功能评估，包括胃泌素-17(G-17)。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "G-17可评估胃窦粘膜功能，结合PGI/PGII比值，提高胃癌筛查效能。",
      "applicable_risks": ["胃癌", "胃部不适"],
      "age_recommendation": "45岁以上胃癌高风险人群",
      "personal_explanations": {
        "default": "胃功能全项在胃功能3项基础上增加了胃泌素-17（G-17）检测。G-17由胃窦细胞分泌，可以评估胃窦粘膜功能和胃酸分泌状态。G-17水平异常提示胃粘膜萎缩或胃癌风险增加。",
        "age_above_45": "45岁以上是胃癌高发年龄段。胃功能全项可以：① 全面评估胃粘膜萎缩程度；② 判断萎缩发生的部位（胃体或胃窦）；③ 识别胃癌高危人群，指导是否需要胃镜检查。这是比胃功能3项更全面的筛查方案。",
        "with_family_history": "您有胃癌家族史，属于胃癌高危人群。胃功能全项比普通胃功能3项多检测G-17，可以更精准地评估您的胃癌风险。如果结果异常，医生会建议您做胃镜进行活检确认。"
      }
    },

    "item142_hba1c": {
      "item_id": "item142",
      "item_name": "糖化血红蛋白",
      "original_name": "糖化血红蛋白 (HbA1c)",
      "evidence": "依据国家卫建委《成人健康体检项目推荐指引（2025年版）》，糖尿病风险人群建议加查糖化血红蛋白，反映近2-3个月平均血糖水平。",
      "source": "国家卫建委《成人健康体检项目推荐指引（2025年版）》",
      "benefit": "反映过去2-3个月的平均血糖水平，是评估血糖控制情况和糖尿病诊断的关键指标，不受短期饮食影响。",
      "applicable_risks": ["高血糖/糖尿病", "心脑血管", "脂肪肝/饮酒"],
      "age_recommendation": "40岁以上，或有糖尿病风险因素者",
      "personal_explanations": {
        "default": "糖化血红蛋白（HbA1c）是红细胞中的血红蛋白与血糖结合的产物，可以反映过去2-3个月的平均血糖水平。与空腹血糖不同，HbA1c不受短期饮食或运动影响，是评估血糖控制情况的'金标准'。",
        "age_above_40": "40岁以后，糖尿病发病率显著上升。《中国2型糖尿病防治指南》指出：40岁以上人群应将HbA1c纳入常规筛查。HbA1c≥6.5%可诊断糖尿病，5.7-6.4%提示糖尿病前期，此时通过生活方式干预可以逆转。",
        "with_hypertension": "高血压和糖尿病常常'结伴而行'，称为'代谢综合征'。研究显示，约60-70%的高血压患者存在胰岛素抵抗。HbA1c可以：① 排查您是否已经处于糖尿病前期；② 评估代谢综合征的严重程度；③ 为综合干预提供依据。",
        "with_family_history": "您有糖尿病家族史，这意味着您的胰岛β细胞可能天生较弱，发病风险比普通人高2-4倍。HbA1c可以：① 监测您的血糖是否已经开始升高；② 及早发现糖尿病前期，此时通过饮食控制、运动、减重可以预防或延缓糖尿病发生。",
        "with_fatty_liver": "脂肪肝与糖尿病关系密切，约30-50%的脂肪肝患者同时存在血糖异常。HbA1c可以：① 评估您的血糖代谢是否已经受损；② 判断脂肪肝对代谢的影响程度；③ 指导脂肪肝的综合管理。"
      }
    },

